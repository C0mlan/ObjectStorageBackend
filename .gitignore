```gitignore
# ==========================================================
# Build Artifacts
# ==========================================================

**/target/
build/
*.class

# Maven Wrapper
# Newer Maven Wrapper versions download this automatically.
.mvn/wrapper/maven-wrapper.jar

# ==========================================================
# Environment & Secrets
# ==========================================================

.env
.env.local
.env.*.local

# Uncomment if this file contains real credentials.
# src/main/resources/secrets.properties

# ==========================================================
# Logs
# ==========================================================

logs/
*.log

# ==========================================================
# IntelliJ IDEA
# ==========================================================

.idea/
*.iml
*.ipr
*.iws
out/

# ==========================================================
# VS Code
# ==========================================================

.vscode/
*.code-workspace
.history/

# ==========================================================
# Eclipse / Spring Tool Suite
# ==========================================================

.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# ==========================================================
# Operating System
# ==========================================================

.DS_Store
Thumbs.db

# ==========================================================
# Docker
# ==========================================================

# Uncomment if using local Docker volumes
# docker/postgres_data/
# docker/redis_data/

# ==========================================================
# Miscellaneous
# ==========================================================

HELP.md
```
